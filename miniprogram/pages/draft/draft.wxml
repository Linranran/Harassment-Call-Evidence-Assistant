<view class="page">
  <view class="section">
    <view class="section-title">投诉文案</view>
    <view class="section-subtitle">根据已保存的骚扰记录生成。提交前请自行核对事实和号码。</view>
    <view class="score-box">
      <view class="score-number">{{score.score}}</view>
      <view>
        <view class="score-label">证据完整度：{{score.level}}</view>
        <view class="muted">公司名、录音和明确营销内容越完整，投诉越有力。</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="field">
      <view class="label">本人手机号，可选</view>
      <input class="input" value="{{userPhone}}" bindinput="updateUserPhone" placeholder="不填则文案显示“本人手机号”" />
    </view>
    <view class="field">
      <view class="label">运营商</view>
      <picker mode="selector" range="{{carriers}}" bindchange="updateCarrier">
        <view class="picker-value">{{carrier}}</view>
      </picker>
    </view>
    <button class="button button-primary" bindtap="refreshDrafts">重新生成</button>
  </view>

  <view wx:if="{{records.length === 0}}" class="section empty">暂无骚扰记录，请先到“取证”页添加。</view>

  <view wx:for="{{drafts}}" wx:key="channel" class="section">
    <view class="row">
      <view>
        <view class="section-title">{{item.title}}</view>
        <view class="section-subtitle">{{item.channel}}</view>
      </view>
      <button class="copy-button" data-content="{{item.content}}" bindtap="copyDraft">复制</button>
    </view>
    <textarea class="draft-content" value="{{item.content}}" disabled />
    <view class="channel-item inline-channel">
      <view class="channel-main">
        <view class="channel-title">{{item.contact.title}}</view>
        <view class="channel-contact">{{item.contact.contact}}</view>
        <view class="muted">{{item.contact.tip}}</view>
      </view>
      <button class="copy-button copy-contact" data-contact="{{item.contact.contact}}" bindtap="copyContact">复制入口</button>
    </view>
    <view class="draft-actions">
      <button class="button button-secondary" data-channel="{{item.channel}}" bindtap="createProgress">记录为待提交</button>
    </view>
  </view>
</view>
