.tool-panel {
  background: #0f766e;
  border-radius: 8rpx;
  color: #ffffff;
  margin-bottom: 24rpx;
  padding: 36rpx 30rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.25;
}

.hero-subtitle {
  color: #ccfbf1;
  font-size: 27rpx;
  line-height: 1.55;
  margin-top: 14rpx;
}

.stats-row {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(2, 1fr);
  margin-top: 28rpx;
}

.stat-item {
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 8rpx;
  padding: 18rpx;
}

.stat-number {
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.1;
}

.stat-label {
  color: #ccfbf1;
  font-size: 23rpx;
  margin-top: 8rpx;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.text-button {
  background: transparent;
  color: #ccfbf1;
  font-size: 24rpx;
  height: 58rpx;
  line-height: 58rpx;
  margin: 12rpx 0 0;
  padding: 0;
}

.tool-panel .button-primary {
  background: #ffffff;
  color: #0f766e;
}

.tool-panel .button-ghost {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.35);
  color: #ffffff;
}

.small-button {
  background: #0f766e;
  border-radius: 8rpx;
  color: #ffffff;
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  padding: 0 20rpx;
}

.record {
  border-top: 1rpx solid #eaecf0;
  padding: 22rpx 0;
}

.record-phone {
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
}

.record-summary {
  color: #344054;
  font-size: 26rpx;
  line-height: 1.5;
  margin-top: 14rpx;
}

.record-actions {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.mini-button {
  background: #f2f4f7;
  border-radius: 8rpx;
  color: #344054;
  font-size: 23rpx;
  height: 56rpx;
  line-height: 56rpx;
  margin: 0;
  padding: 0 18rpx;
}

.mini-button.danger {
  background: #fff1f2;
  color: #be123c;
}
